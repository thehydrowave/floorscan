# ─── FloorScan — Variables d'environnement ────────────────────────────────────
# Copiez ce fichier en ".env" (backend) ou "frontend/.env.local" (frontend)

# ── Backend (Python / FastAPI) ─────────────────────────────────────────────
# Port d'écoute (défaut: 8000)
PORT=8000

# ── Frontend (Next.js) ────────────────────────────────────────────────────
# URL du backend FastAPI (copiez dans frontend/.env.local)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
