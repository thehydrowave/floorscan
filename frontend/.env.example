# ─── FloorScan Frontend — Variables d'environnement ─────────────────────────
# Copiez ce fichier en ".env.local" et remplissez les valeurs

# URL du backend FastAPI
# En développement local : http://localhost:8000
# En production : https://your-backend.railway.app (ou autre hébergeur)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ─── Auth (NextAuth.js v5) ──────────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=your-random-secret-here
AUTH_URL=http://localhost:3000

# Default admin account (seeded on first DB access)
ADMIN_EMAIL=admin@floorscan.local
ADMIN_PASSWORD=change-me-in-production
